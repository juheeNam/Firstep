{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__github__create_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-create-pr.sh",
            "timeout": 10,
            "statusMessage": "QA 리뷰 수행 여부 확인 중..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "qa-tester",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/qa-tester-stop.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
